# See https://git-scm.com/docs/gitattributes for more about git attribute files.

# Mark the database schema as having been generated.
db/schema.rb linguist-generated

# Mark any vendored files as having been vendored.
vendor/* linguist-vendored

# Mark VCR cassettes as generated so AI tools and GitHub stats skip them.
spec/support/fixtures/vcr_cassettes/** linguist-generated

# OpenAPI pipeline outputs — generated by script/openapi/merger.rb and the
# rspec-openapi recorder. See script/openapi/README.md for the source-of-truth
# chain. linguist-generated collapses the file in GitHub diffs and excludes it
# from language stats; merge=binary prevents three-way merge attempts (the
# regen pipeline is the merge tool).
docs/openapi.yaml                       linguist-generated merge=binary
docs/openapi.yaml.handwritten.bak       linguist-generated merge=binary
script/openapi/cached/from_rspec.yaml   linguist-generated merge=binary

config/credentials/*.yml.enc diff=rails_credentials
config/credentials.yml.enc diff=rails_credentials
